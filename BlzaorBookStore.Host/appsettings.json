{
  "App": {
    "SelfUrl": "https://localhost:44355",
    "CorsOrigins": "https://*.BlzaorBookStore.com,http://localhost:44355",
    "RedirectAllowedUrls": "http://localhost:44355"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/logs.txt"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": "Server=(LocalDb)\\MSSQLLocalDB;Database=BlzaorBookStore;Trusted_Connection=True;TrustServerCertificate=true"
  },
  "AuthServer": {
    "Authority": "https://localhost:44355",
    "SwaggerClientId": "BlzaorBookStore_Swagger",
    "CertificatePassPhrase": "a2b7df09-347d-427a-804e-b4745b4aee76"
  },
  "Settings": {
    "Abp.Identity.Password.RequireNonAlphanumeric": "false",
    "Abp.Identity.Password.RequireLowercase": "false",
    "Abp.Identity.Password.RequireUppercase": "false",
    "Abp.Identity.Password.RequireDigit": "false"
  },
  "StringEncryption": {
    "DefaultPassPhrase": "7EmlEWYjEL12HNsq"
  },
  "OpenIddict": {
    "Applications": {
      "BlzaorBookStore_Blazor": {
        "ClientId": "BlzaorBookStore_Blazor",
